# Arduino build artifacts
build/
*.hex
*.bin
*.elf
*.map

# Exception: hosted assets in /model/ (e.g. transmitter model files)
!model/*.bin

# Exception: firmware images served to the in-browser flasher (built by
# .github/workflows/build-firmware.yml and committed back to main).
!firmware/*.bin

# Editor / IDE
.vscode/
.idea/
*.code-workspace
*.swp
*.bak
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Claude Code worktree / session state
.claude/
