#!/bin/sh
# ─────────────────────────────────────────────────────────────────────────
# Pre-commit hook: stamp the current Date-Time-Group into TWO places:
#
#   1. config_tool/index.html — UI footer span (#footer-dtg)
#   2. fw_version.h            — FW_VERSION_DTG #define (firmware version)
#
# This keeps the GUI's footer and the firmware's reported version in
# lock-step: both reflect the moment the commit was made, in the same
# format used everywhere else in the project.
#
# Format:  DDHHMM<TZ>MMMYY   (e.g. 211520QMAY26)
#   DD      day of month, local time, zero-padded
#   HHMM    24-hour local time
#   TZ      military timezone letter derived from UTC offset
#           (R = UTC-5 EST, Q = UTC-4 EDT, etc.; falls back to 'R')
#   MMM     three-letter month, uppercase
#   YY      two-digit year
#
# Uses /bin/sh (POSIX) instead of bash so GitHub Desktop on Windows can
# run it via the Git-for-Windows MSYS shell without invoking WSL.
#
# Activation (one-time, per clone):
#     git config core.hooksPath tools/git-hooks
#     git update-index --chmod=+x tools/git-hooks/pre-commit
#
# Non-blocking: if anything fails, the commit still proceeds without the
# stamp — better a missing DTG than a blocked workflow.
# ─────────────────────────────────────────────────────────────────────────

HTML_FILE="config_tool/index.html"
FWVER_FILE="fw_version.h"

# Bail silently if BOTH target files are absent (e.g. running in an
# unrelated worktree). Individual missing files are handled per-target
# below so the hook still partially works if only one is present.
if [ ! -f "$HTML_FILE" ] && [ ! -f "$FWVER_FILE" ]; then
  exit 0
fi

# ── Build the DTG ────────────────────────────────────────────────────────
DAY=$(date +%d)
HHMM=$(date +%H%M)
MONTH=$(date +%b | tr '[:lower:]' '[:upper:]')
YEAR=$(date +%y)

# Map common UTC offsets → military TZ letter. Falls back to 'R' for any
# offset not listed (matches user's firmware-version convention).
OFFSET=$(date +%z)
case "$OFFSET" in
  +0000) TZ_LETTER="Z" ;;
  -0500) TZ_LETTER="R" ;;   # EST
  -0400) TZ_LETTER="Q" ;;   # EDT
  -0600) TZ_LETTER="S" ;;   # CST
  -0500) TZ_LETTER="R" ;;   # CDT — same letter as EST (handled above)
  -0700) TZ_LETTER="T" ;;   # MST / PDT
  -0800) TZ_LETTER="U" ;;   # PST
  +0100) TZ_LETTER="A" ;;
  +0200) TZ_LETTER="B" ;;
  +0900) TZ_LETTER="I" ;;
  +1000) TZ_LETTER="K" ;;
  *)     TZ_LETTER="R" ;;   # fallback
esac

DTG="${DAY}${HHMM}${TZ_LETTER}${MONTH}${YEAR}"

# Helper: patch FILE in place by running sed-script EXPR; stage the file
# only if it actually changed. Avoids leaving the working tree dirty when
# the DTG happens to match (re-commit within the same minute).
stamp_file() {
  FILE="$1"; EXPR="$2"; LABEL="$3"
  [ -f "$FILE" ] || return 0
  TMP=$(mktemp 2>/dev/null || mktemp -t dtg)
  sed -E "$EXPR" "$FILE" > "$TMP" 2>/dev/null
  if [ -s "$TMP" ] && ! cmp -s "$FILE" "$TMP"; then
    mv "$TMP" "$FILE"
    git add "$FILE"
    echo "[pre-commit] ${LABEL} DTG stamped: ${DTG}"
  else
    rm -f "$TMP"
  fi
}

# ── Patch the UI footer (<span id="footer-dtg">…</span>) ────────────────
stamp_file "$HTML_FILE" \
  "s|(<span id=\"footer-dtg\">)[^<]*(</span>)|\\1${DTG}\\2|" \
  "UI footer"

# ── Patch the firmware version (#define FW_VERSION_DTG  "…") ────────────
# Match any whitespace between the macro name and the opening quote so the
# format can be re-aligned without breaking the hook.
stamp_file "$FWVER_FILE" \
  "s|(#define[[:space:]]+FW_VERSION_DTG[[:space:]]+\")[^\"]*(\")|\\1${DTG}\\2|" \
  "FW version"

exit 0
